// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  WAITING
  LIVE
  ENDED
}

enum RoomParticipantRole {
  LEARNER
  MENTOR
  HOST
}

model Room {
  id               String            @id @default(uuid())
  name             String
  description      String?
  level            String?
  status           RoomStatus        @default(WAITING)
  agoraChannelName String            @unique
  hostUserId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  participants     RoomParticipant[]

  @@index([status])
  @@index([hostUserId])
}

model RoomParticipant {
  id             String              @id @default(uuid())
  roomId         String
  userId         String
  displayName    String?
  avatarPersona  String?
  role           RoomParticipantRole @default(LEARNER)
  rawRole        String?
  isAnonymous    Boolean             @default(true)
  isMicOn        Boolean             @default(false)
  isVideoEnabled Boolean             @default(false)
  isHandRaised   Boolean             @default(false)
  isSpeaker      Boolean             @default(false)
  agoraUid       String
  joinedAt       DateTime            @default(now())
  leftAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, leftAt])
  @@index([roomId, userId])
}
