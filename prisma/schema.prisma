generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  OPEN
  CLOSED
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum RoleInSession {
  SUPER
  HOST
  STUDENT
}

enum HandRaiseRequestStatus {
  WAITING
  APPROVED
  REJECTED
  CANCELLED
  FINISHED
}

enum RecordingProvider {
  MOCK
  AGORA_CLOUD_RECORDING
  CLOUDFLARE_STREAM
}

enum RecordingStatus {
  REQUESTED
  RECORDING
  PROCESSING
  READY
  FAILED
  DELETED
}

enum RecordingAccessAction {
  VIEW
  DOWNLOAD
  DENIED
}

enum AccessResult {
  ALLOWED
  DENIED
}

model Room {
  roomId             String        @id
  title              String
  hostAnonymousId    String
  externalCourseId   String?
  externalLevelId    String?
  externalSubLevelId String?
  defaultChannelName String
  status             RoomStatus    @default(OPEN)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  liveSessions       LiveSession[]
  recordings         Recording[]

  @@index([hostAnonymousId])
  @@index([status])
  @@map("rooms")
}

model LiveSession {
  sessionId         String               @id
  roomId            String
  channelName       String
  status            LiveSessionStatus    @default(SCHEDULED)
  startedAt         DateTime
  endedAt           DateTime?
  peakParticipants  Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  room              Room                 @relation(fields: [roomId], references: [roomId], onDelete: Cascade)
  participants      SessionParticipant[]
  handRaiseRequests HandRaiseRequest[]
  recordings        Recording[]

  @@index([roomId])
  @@index([status])
  @@map("live_sessions")
}

model SessionParticipant {
  participantId        String        @id @default(cuid())
  sessionId            String
  anonymousUserId      String
  displayName          String
  roleInSession        RoleInSession
  joinedAt             DateTime      @default(now())
  leftAt               DateTime?
  totalSpeakingSeconds Int           @default(0)
  session              LiveSession   @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@unique([sessionId, anonymousUserId])
  @@index([sessionId, leftAt])
  @@map("session_participants")
}

model HandRaiseRequest {
  requestId       String                 @id @default(cuid())
  sessionId       String
  anonymousUserId String
  status          HandRaiseRequestStatus @default(WAITING)
  requestedAt     DateTime               @default(now())
  handledAt       DateTime?
  handledBy       String?
  session         LiveSession            @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([anonymousUserId])
  @@map("hand_raise_requests")
}

model Recording {
  recordingId        String               @id @default(cuid())
  sessionId          String
  roomId             String
  createdBySuperId   String
  externalCourseId   String?
  externalLevelId    String?
  externalSubLevelId String?
  provider           RecordingProvider    @default(MOCK)
  agoraResourceId    String?
  agoraSid           String?
  cloudflareVideoUid String?
  providerMetadata   Json?
  status             RecordingStatus      @default(REQUESTED)
  title              String?
  startedAt          DateTime
  endedAt            DateTime?
  durationSeconds    Int?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  session            LiveSession          @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  room               Room                 @relation(fields: [roomId], references: [roomId], onDelete: Cascade)
  accessLogs         RecordingAccessLog[]

  @@index([sessionId, status])
  @@index([roomId])
  @@map("recordings")
}

model RecordingAccessLog {
  accessLogId     String                @id @default(cuid())
  recordingId     String
  anonymousUserId String
  action          RecordingAccessAction
  result          AccessResult
  reason          String
  createdAt       DateTime              @default(now())
  recording       Recording             @relation(fields: [recordingId], references: [recordingId], onDelete: Cascade)

  @@index([recordingId])
  @@index([anonymousUserId])
  @@map("recording_access_logs")
}
